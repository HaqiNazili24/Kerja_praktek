APP_NAME=TokoBerasKu
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tokoberasku
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@tokoberasku.test"
MAIL_FROM_NAME="${APP_NAME}"

STORE_NAME="TokoBerasKu"
STORE_BANK_NAME="Bank BCA"
STORE_BANK_ACCOUNT="1234567890"
STORE_BANK_HOLDER="PT TokoBerasKu Sejahtera"
SHIPPING_FLAT_RATE=10000
